{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "Information about the restaurant/shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "whatsapp": { "type": "string", "description": "WhatsApp number in international format" },
        "ownerId": { "type": "string" },
        "address": { "type": "string" },
        "logoUrl": { "type": "string" },
        "deliveryFee": { "type": "number", "description": "Fixed delivery fee amount" },
        "slug": { "type": "string", "description": "Unique identifier for the store's public URL" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "whatsapp", "ownerId", "slug"]
    },
    "Category": {
      "title": "Category",
      "description": "Menu categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "storeId": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name", "storeId"]
    },
    "Product": {
      "title": "Product",
      "description": "Menu items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "categoryId": { "type": "string" },
        "storeId": { "type": "string" },
        "available": { "type": "boolean" }
      },
      "required": ["name", "price", "categoryId", "storeId"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "items": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Novo", "Em preparo", "Finalizado", "Cancelado"] },
        "orderNumber": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["storeId", "customerName", "items", "total", "status", "orderNumber"]
    }
  },
  "firestore": {
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Main store collection"
    },
    "/stores/{storeId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "Categories belonging to a store"
    },
    "/stores/{storeId}/products/{productId}": {
      "schema": "Product",
      "description": "Products belonging to a store"
    },
    "/stores/{storeId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders belonging to a store"
    }
  }
}
